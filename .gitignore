# Dependencies
app/node_modules/
app/.pnp
app/.pnp.*
app/.yarn/*
!app/.yarn/patches
!app/.yarn/plugins
!app/.yarn/releases
!app/.yarn/versions

# Next.js build outputs
app/.next/
app/out/
app/build/
app/*.tsbuildinfo
app/next-env.d.ts

# SQLite local databases
app/*.db
app/*.db-shm
app/*.db-wal

# OS specific files
.DS_Store
Thumbs.db
*.DS_Store

# Environment files
app/.env*
!app/.env.local.example

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Vercel
app/.vercel
